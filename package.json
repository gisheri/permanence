{
  "name": "@permanence/monorepo",
  "version": "0.4.0",
  "description": "A suite of utility packages that never change",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "website"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "clean": "nx run-many -t clean",
    "dev": "nx run-many -t dev",
    "typecheck": "nx run-many -t typecheck",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint:fix",
    "format": "nx run-many -t format",
    "format:check": "nx run-many -t format:check",
    "check": "nx run-many -t check",
    "test": "nx run-many -t test",
    "test:run": "nx run-many -t test:run",
    "test:coverage": "nx run-many -t test:coverage",
    "test:coverage-check": "nx run-many -t test:coverage-check",
    "benchmark": "nx run-many -t benchmark",
    "benchmark:run": "nx run-many -t benchmark:run",
    "bundlesize": "nx run-many -t bundlesize",
    "version-packages": "nx release version",
    "publish-packages": "nx release publish",
    "release": "nx run-many -t build && nx release --skip-publish && nx release publish",
    "generate-packages": "node scripts/generate-packages.js",
    "docs:dev": "npm --prefix website start",
    "docs:build": "npm --prefix website run build",
    "docs:serve": "npm --prefix website run serve"
  },
  "keywords": [
    "utilities",
    "typescript",
    "tree-shakeable",
    "functional",
    "string",
    "object",
    "lodash",
    "ramda",
    "zero-dependencies"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "~8.57.0",
    "@nx/eslint": "21.1.2",
    "@nx/eslint-plugin": "21.1.2",
    "@nx/js": "^21.1.2",
    "@nx/vite": "21.1.2",
    "@nx/web": "21.1.2",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/eslint": "^9.6.1",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "@vitest/coverage-v8": "^3.1.4",
    "@vitest/ui": "^3.1.4",
    "bundlesize": "^0.18.2",
    "esbuild": "^0.19.0",
    "eslint": "^9.28.0",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "22.5.4",
    "prettier": "^3.5.3",
    "tslib": "^2.3.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.33.0",
    "verdaccio": "^6.0.5",
    "vite": "^6.0.0",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "access": "public"
  },
  "nx": {
    "includedScripts": []
  },
  "dependencies": {}
}
