{
  "name": "@permanence/utility",
  "version": "0.0.1",
  "description": "General utilities that never change",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.cjs"
    }
  },
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "index.cjs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "utility",
    "utilities",
    "typescript",
    "tree-shakeable",
    "cloneDeep"
  ],
  "homepage": "https://github.com/yourusername/permanence#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/permanence.git",
    "directory": "packages/utility"
  },
  "bugs": "https://github.com/yourusername/permanence/issues",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@permanence/cloneDeep": "0.0.1"
  }
}
